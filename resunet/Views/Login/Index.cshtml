@model LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<form action="/login" method="post">
    <div>
        <label>Email</label>
        <input name="Email" type="text" />
    </div>
    
    <div>
        <label>Password</label>
        <input name="Password" type="password" />
    </div>

    <button>Login</button>
</form>