@model LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<form action="/login" method="post">
    <div>
        <label>Email</label>
        <!-- use 'value' attribute so when there's an error, email is still filled -->
        <input name="Email" type="text" value="@Model.Email" />
        <div class="error">@Html.ValidationMessageFor(m => m.Email)</div>
    </div>
    
    <div>
        <label>Password</label>
        <input name="Password" type="password" />
        <div class="error">@Html.ValidationMessageFor(m => m.Password)</div>
    </div>

    <button>Login</button>
</form>